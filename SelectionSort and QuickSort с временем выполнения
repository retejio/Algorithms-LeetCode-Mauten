import random
import time
import matplotlib.pyplot as plt


def selection_sort(arr):
    n = len(arr)

    for i in range(n - 1):
        min_index = i

        for j in range(i + 1, n):
            if arr[j] < arr[min_index]:
                min_index = j

        arr[i], arr[min_index] = arr[min_index], arr[i]

    return arr


def quick_sort(arr):
    if len(arr) <= 1:
        return arr

    pivot = arr[len(arr) // 2]

    left = [x for x in arr if x < pivot]
    middle = [x for x in arr if x == pivot]
    right = [x for x in arr if x > pivot]

    return quick_sort(left) + middle + quick_sort(right)


def generate_random(n):
    return [random.randint(0, 100000) for _ in range(n)]


def measure_average_time(sort_function, arr):

    total = 0

    for i in range(5):  #5 запусков

        start = time.perf_counter()

        sort_function(arr.copy())

        end = time.perf_counter()

        total += end - start

    return total / 5  #среднее время


sizes = [1000, 5000, 10000, 20000]

selection_times = []
quick_times = []

for size in sizes:

    arr = generate_random(size)

    selection_times.append(measure_average_time(selection_sort, arr))
    quick_times.append(measure_average_time(quick_sort, arr))


plt.plot(sizes, selection_times, label="Selection Sort")
plt.plot(sizes, quick_times, label="Quick Sort")

plt.xlabel("Размер массива")
plt.ylabel("Среднее время (сек)")

plt.title("Сравнение алгоритмов сортировки")

plt.legend()

plt.show()
