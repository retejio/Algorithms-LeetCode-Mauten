def selection_sort(arr):
    n = len(arr)  

    for i in range(n - 1):  #проходим по всем элементам массива кроме последнего
        min_index = i  #предполагаем что минимальный элемент находится на позиции i

        for j in range(i + 1, n):  #ищем минимальный элемент в неотсортированной части массива
            if arr[j] < arr[min_index]:
                min_index = j  

        arr[i], arr[min_index] = arr[min_index], arr[i]  #меняем местами текущий элемент и найденный минимальный

    return arr  #возвращаем отсортированный массив
